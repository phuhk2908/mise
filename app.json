{
  "expo": {
    "name": "mise",
    "slug": "mise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Mise uses the microphone to transcribe your spoken recipes into text.",
        "NSSpeechRecognitionUsageDescription": "Mise uses speech recognition to turn your voice into structured recipes.",
        "NSCameraUsageDescription": "Mise uses the camera to capture recipe images for extraction.",
        "NSPhotoLibraryUsageDescription": "Mise uses your photo library to select recipe images for extraction."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF0",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "package": "com.fuofuo.mise"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF6F0",
          "dark": {
            "backgroundColor": "#141414",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f8ab92c-e5fe-43bb-b8f0-31bd336571bd"
      }
    }
  }
}
