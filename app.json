{
  "expo": {
    "name": "mise",
    "slug": "mise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Mise uses the microphone to record audio notes of your recipes.",
        "NSCameraUsageDescription": "Mise uses the camera to capture recipe photos.",
        "NSPhotoLibraryUsageDescription": "Mise accesses your photos to let you choose recipe images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF0",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF6F0",
          "dark": {
            "backgroundColor": "#141414",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Mise accesses your photos to let you choose recipe images.",
          "cameraPermission": "Mise uses the camera to capture recipe photos."
        }
      ],
      "expo-localization",
      "expo-sqlite",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
